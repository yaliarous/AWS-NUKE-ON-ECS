{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "enabledManagers": ["dockerfile"],
  "packageRules": [
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["ghcr.io/ekristen/aws-nuke"],
      "versioning": "semver",
      "automerge": false,
      "labels": ["dependencies", "docker"]
    }
  ]
}